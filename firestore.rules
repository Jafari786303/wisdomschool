rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function role() {
      return signedIn() && userDoc().exists() ? userDoc().data.role : '';
    }
    function isAdmin() {
      return role() == 'admin';
    }
    function isDeveloper() {
      return role() == 'developer' || role() == 'admin';
    }
    function isParticipant(project) {
      return signedIn() && (
        project.customerId == request.auth.uid ||
        project.acceptedDeveloperId == request.auth.uid ||
        isAdmin()
      );
    }

    match /users/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow update: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if false;
    }

    match /projects/{projectId} {
      allow create: if signedIn() && request.resource.data.customerId == request.auth.uid;
      allow read: if signedIn() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.acceptedDeveloperId == request.auth.uid ||
        (isDeveloper() && resource.data.status == 'pending' && resource.data.acceptedDeveloperId == '') ||
        isAdmin()
      );
      allow update: if signedIn() && (
        isAdmin() ||
        (isDeveloper() && resource.data.status == 'pending' && resource.data.acceptedDeveloperId == '' && request.resource.data.acceptedDeveloperId == request.auth.uid) ||
        (isDeveloper() && resource.data.acceptedDeveloperId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow create: if signedIn() && (request.auth.uid in request.resource.data.participants || isAdmin());
      allow read, update: if signedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if signedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow create: if signedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants || isAdmin());
        allow update, delete: if false;
      }
    }
  }
}
