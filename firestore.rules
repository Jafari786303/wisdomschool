rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function myUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRole() {
      return signedIn() && myUserDoc().data.role;
    }

    function isAdmin() {
      return signedIn() && myRole() == "admin";
    }

    function isTeacher() {
      return signedIn() && myRole() == "teacher";
    }

    function isPrincipal() {
      return signedIn() && myRole() == "principal";
    }

    function isStudent() {
      return signedIn() && myRole() == "student";
    }

    function isStaff() {
      return isAdmin() || isTeacher() || isPrincipal();
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read: if signedIn();
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin() || isPrincipal());
      allow delete: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /studentApplications/{applicationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || isPrincipal();
    }

    match /teacherApplications/{applicationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || isPrincipal();
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid in request.resource.data.memberIds;
      allow update: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow delete: if isAdmin() || isPrincipal();

      match /messages/{messageId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update, delete: if isAdmin() || isPrincipal();
      }
    }

    match /tasks/{taskId} {
      allow read: if signedIn();
      allow create, update, delete: if isStaff();
    }

    match /lessons/{lessonId} {
      allow read: if signedIn();
      allow create, update, delete: if isStaff();
    }

    match /scores/{scoreId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin() || isTeacher() || isPrincipal();
    }
  }
}
